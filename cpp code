#include <iostream>
#include <vector>
#include <algorithm>
#include <map>
using namespace std;

// ---------------- STRUCTS ----------------
struct Ball {
    string over;
    string event;
    int runs;
    string batsman;
};

struct Highlight {
    string over;
    string event;
    int score;
    string text;
};

// ---------------- PARSE OVER ----------------
pair<int,int> parseOver(string s) {
    int over = 0, ball = 0, i = 0;

    while (s[i] != '.') {
        over = over * 10 + (s[i] - '0');
        i++;
    }
    i++;

    while (i < s.size()) {
        ball = ball * 10 + (s[i] - '0');
        i++;
    }

    return {over, ball};
}

// ---------------- COMMENTARY ENGINE ----------------
string generateComment(string event, int over) {

    if (event == "SIX") {
        if (over >= 18) return "WHAT A SIX! Pressure? What pressure!";
        return "SIX! Massive hit!";
    }
    else if (event == "FOUR") {
        return "FOUR! Classy shot!";
    }
    else if (event == "WICKET") {
        if (over >= 16) return "WICKET! GAME CHANGER!";
        return "WICKET! Big breakthrough!";
    }
    else if (event.find("HALF") != string::npos) {
        return "Half Century! Brilliant innings!";
    }
    else if (event.find("CENTURY") != string::npos) {
        return "CENTURY! Outstanding performance!";
    }

    return event;
}

// ---------------- SCORING ENGINE ----------------
int getScore(string event, int over) {

    int base = 1;

    if (event == "WICKET") base = 10;
    else if (event == "CENTURY") base = 9;
    else if (event == "HALF_CENTURY") base = 8;
    else if (event == "SIX") base = 7;
    else if (event == "FOUR") base = 6;

    // Pressure boost
    if (over >= 16) base += 3;
    else if (over >= 10) base += 1;

    // Clutch moments
    if (event == "WICKET" && over >= 16) base += 2;
    if (event == "SIX" && over >= 18) base += 2;

    return base;
}

// ---------------- MAIN ----------------
int main() {

    vector<Ball> match;
    int n;

    cout << "Enter number of balls: ";
    cin >> n;

    cout << "\nEnter data (over event runs batsman)\n";
    cout << "Example: 18.1 SIX 6 A\n\n";

    // -------- INPUT --------
    for (int i = 0; i < n; i++) {
        Ball b;
        cin >> b.over >> b.event >> b.runs >> b.batsman;
        match.push_back(b);
    }

    vector<Highlight> all;

    map<string,int> batterRuns;
    map<string,int> playerImpact;
    map<string,bool> halfDone, centuryDone;

    // -------- PROCESS --------
    for (auto b : match) {

        int overNum = parseOver(b.over).first;
        batterRuns[b.batsman] += b.runs;

        // Milestones
        if (batterRuns[b.batsman] >= 100 && !centuryDone[b.batsman]) {
            all.push_back({b.over, b.batsman + "_CENTURY",
                           getScore("CENTURY", overNum),
                           generateComment("CENTURY", overNum)});
            centuryDone[b.batsman] = true;
        }
        else if (batterRuns[b.batsman] >= 50 && !halfDone[b.batsman]) {
            all.push_back({b.over, b.batsman + "_HALF_CENTURY",
                           getScore("HALF_CENTURY", overNum),
                           generateComment("HALF_CENTURY", overNum)});
            halfDone[b.batsman] = true;
        }

        // Main events
        if (b.event == "SIX" || b.event == "FOUR" || b.event == "WICKET") {

            int score = getScore(b.event, overNum);

            all.push_back({b.over, b.event,
                           score,
                           generateComment(b.event, overNum)});

            // Player impact score
            playerImpact[b.batsman] += score;
        }
    }

    // -------- SORT BY SCORE --------
    sort(all.begin(), all.end(), [](Highlight a, Highlight b) {
        return a.score > b.score;
    });

    vector<Highlight> finalH;

    // -------- TOP 20 --------
    for (int i = 0; i < all.size() && finalH.size() < 20; i++) {
        finalH.push_back(all[i]);
    }

    // -------- SORT BY MATCH ORDER --------
    sort(finalH.begin(), finalH.end(), [](Highlight a, Highlight b) {
        auto p1 = parseOver(a.over);
        auto p2 = parseOver(b.over);

        if (p1.first == p2.first)
            return p1.second < p2.second;

        return p1.first < p2.first;
    });

    // -------- OUTPUT --------
    cout << "\n==============================\n";
    cout << " IPL STYLE MATCH HIGHLIGHTS\n";
    cout << "==============================\n";

    for (auto h : finalH) {

        int overNum = parseOver(h.over).first;

        if (h.over == "1.1") cout << "\n POWERPLAY\n";
        if (h.over == "7.1") cout << "\n MIDDLE OVERS\n";
        if (h.over == "16.1") cout << "\n DEATH OVERS\n";

        cout << "-> " << h.over << " | " << h.text << endl;
    }

    // -------- PLAYER IMPACT --------
    cout << "\n🏆 PLAYER IMPACT\n";

    vector<pair<string,int>> ranking(playerImpact.begin(), playerImpact.end());

    sort(ranking.begin(), ranking.end(),
         [](auto a, auto b) { return a.second > b.second; });

    for (auto p : ranking) {
        cout << p.first << " -> " << p.second << endl;
    }

    cout << "\n==============================\n";
    cout << " SMART HIGHLIGHTS GENERATED\n";
    cout << "==============================\n";

    return 0;
}
